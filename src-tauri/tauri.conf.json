{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FamVoice",
  "version": "0.3.8",
  "identifier": "com.famvoice.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FamVoice",
        "width": 260,
        "height": 200,
        "transparent": true,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' asset: data: blob:; font-src 'self' data:; media-src 'self' blob:; object-src 'none'; script-src 'self'; style-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost http://tauri.localhost https://tauri.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwNjU5ODIzNkQ1NjZCMzIKUldReWExWnRJNWhsd0RiUUpCa2xJWkliNDB4dE1Saml3WlRheXlldkN2SmNsZWlvWEVMZ2VsbTQK",
      "endpoints": [
        "https://github.com/famintos/FamVoice/releases/latest/download/latest.json"
      ]
    }
  }
}
